# Backend environment variables — copy to .env and fill in real values
# NEVER commit .env to source control

# PostgreSQL connection string
# Format: postgresql+psycopg2://user:password@host:port/dbname
DATABASE_URL=postgresql+psycopg2://advisor_user:devpassword@localhost:5432/advisor_dev

# JWT signing secret — minimum 32 bytes of random data
# Generate with: openssl rand -hex 32
SECRET_KEY=dev-secret-key-do-not-use-in-production-abc123

# JWT signing algorithm
ALGORITHM=HS256

# JWT expiry in minutes (60 for dev, 30 for prod)
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Comma-separated list of allowed CORS origins (no trailing slashes)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
