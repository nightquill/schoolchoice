# Backend environment variables — copy to .env and fill in real values
# NEVER commit .env to source control

# PostgreSQL connection string
# Format: postgresql+psycopg2://user:password@host:port/dbname
DATABASE_URL=postgresql+psycopg2://advisor_user:devpassword@localhost:5432/advisor_dev

# JWT signing secret — minimum 32 bytes of random data
# Generate with: openssl rand -hex 32
SECRET_KEY=dev-secret-key-do-not-use-in-production-abc123

# JWT signing algorithm
ALGORITHM=HS256

# JWT expiry in minutes (60 for dev, 30 for prod)
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Comma-separated list of allowed CORS origins (no trailing slashes)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# AI provider — one of: openai, anthropic, gemini, openai-compatible
AI_PROVIDER=gemini

# AI API key (BYOK — bring your own key)
# Get from: OpenAI dashboard, Anthropic console, or Google AI Studio
AI_API_KEY=

# Optional: override default model (defaults: openai=gpt-4o, anthropic=claude-sonnet-4-20250514, gemini=gemini-2.5-flash)
# AI_MODEL=

# Optional: custom endpoint URL (required only for openai-compatible providers)
# AI_BASE_URL=

# Optional: request timeout in seconds (default: 30)
# AI_TIMEOUT=30
