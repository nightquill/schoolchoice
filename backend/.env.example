# DataPilot Environment Configuration
# Copy to .env and fill in values, or run: bash scripts/generate_secrets.sh
#
# For production deployment, see DEPLOY.md

# === REQUIRED (app will not start without valid values) ===

# Database connection string
# Local dev: postgresql+psycopg2://user:password@localhost:5432/advisor_dev
# Production (Neon): postgresql+psycopg2://user:pass@ep-xxx.neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql+psycopg2://advisor_user:devpassword@localhost:5432/advisor_dev

# Secret key for JWT signing — MUST be changed for production
# Generate with: openssl rand -hex 32
# Or run: bash scripts/generate_secrets.sh
SECRET_KEY=dev-secret-key-do-not-use-in-production-abc123

# === AUTH ===
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# === CORS ===
# Comma-separated allowed origins
# Local dev: http://localhost:5173,http://localhost:3000
# Production: https://your-app.vercel.app
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# === AI Provider (optional — AI features degrade gracefully without API key) ===
# Options: gemini, openai, anthropic, openai-compatible
AI_PROVIDER=gemini

# AI API key (BYOK — bring your own key)
# Get from: OpenAI dashboard, Anthropic console, or Google AI Studio
AI_API_KEY=

# Optional: override default model (defaults: openai=gpt-4o, anthropic=claude-sonnet-4-20250514, gemini=gemini-2.5-flash)
# AI_MODEL=

# Optional: custom endpoint URL (required only for openai-compatible providers)
# AI_BASE_URL=

# Optional: request timeout in seconds (default: 30)
# AI_TIMEOUT=30

# === File Upload ===
# UPLOAD_DIR=/tmp/uploads

# === Plan Generation ===
# PLAN_GENERATION_TIMEOUT_SECONDS=120
