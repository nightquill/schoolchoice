{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": ".claude/hooks/session-start-load-lessons.sh" }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          { "type": "command", "command": ".claude/hooks/research-reminder.sh" }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": ".claude/hooks/block-echo-token.sh" }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          { "type": "command", "command": ".claude/hooks/scope-guard.sh" },
          { "type": "command", "command": ".claude/hooks/no-new-md.sh" },
          { "type": "command", "command": ".claude/hooks/no-fake-data.sh" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "mcp__playwright__browser_take_screenshot",
        "hooks": [
          { "type": "command", "command": ".claude/hooks/playwright-screenshot-guard.sh" }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          { "type": "command", "command": ".claude/hooks/verify-imports.sh" }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": ".claude/hooks/bug-fix-needs-test.sh" },
          { "type": "command", "command": ".claude/hooks/pre-stop-diff-audit.sh" }
        ]
      }
    ]
  }
}
